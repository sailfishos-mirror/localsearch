#: src/cli/tracker-index.c:51
msgid "Adds FILE as an indexed location"
msgstr "ເພີ່ມ ໄຟລ໌ ເປັນຕຳແໜ່ງທີ່ຖືກຈັດດັດຊະນີ"

#: src/cli/tracker-index.c:54
msgid "Removes FILE from indexed locations"
msgstr "ລົບ ໄຟລ໌ ອອກຈາກຕຳແໜ່ງທີ່ຖືກຈັດດັດຊະນີ"

#: src/cli/tracker-index.c:57
msgid "Makes indexing recursive"
msgstr "ເຮັດໃຫ້ການຈັດດັດຊະນີເປັນແບບຕໍ່ເນື່ອງ"

#: src/cli/tracker-index.c:195
#, c-format
msgid "“%s” is not a directory"
msgstr "“%s” ບໍ່ແມ່ນໄດເລກະທໍຣີ"

#. TRANSLATORS: These are commandline options
#: src/cli/tracker-index.c:273
msgid "Either --add or --remove must be provided"
msgstr "ຕ້ອງລະບຸ --add ຫຼື --remove ຢ່າງໃດຢ່າງໜຶ່ງ"

#. TRANSLATORS: These are commandline options
#: src/cli/tracker-index.c:277
msgid "--add and --remove are mutually exclusive"
msgstr "--add ແລະ --remove ບໍ່ສາມາດໃຊ້ຮ່ວມກັນໄດ້"

#. TRANSLATORS: These are commandline options
#: src/cli/tracker-index.c:287
msgid "--recursive requires --add"
msgstr "--recursive ຕ້ອງການ --add"

#: src/cli/tracker-index.c:345 src/cli/tracker-status.c:347
msgid "Path"
msgstr "ເສັ້ນທາງ"

#: src/cli/tracker-index.c:346
msgid "Recursive"
msgstr "ຕໍ່ເນື່ອງ"

#: src/cli/tracker-index.c:388
msgid "Please specify one or more locations to index."
msgstr "ກະລຸນາລະບຸໜຶ່ງຕຳແໜ່ງ ຫຼື ຫຼາຍກວ່ານັ້ນເພື່ອຈັດດັດຊະນີ."

#: src/cli/tracker-info.c:66
msgid "Show full namespaces (i.e. don’t use nie:title, use full URLs)"
msgstr "ສະແດງຊື່ເຕັມ (ເຊັ່ນ: ບໍ່ໃຊ້ nie:title, ໃຫ້ໃຊ້ URLs ແບບເຕັມ)"

