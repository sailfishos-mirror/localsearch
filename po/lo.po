#: data/org.freedesktop.Tracker.Extract.gschema.xml:23
msgid "Max bytes to extract"
msgstr "ຂະໜາດໄບຕ໌ສູງສຸດທີ່ຈະສະກັດ"

#: data/org.freedesktop.Tracker.Extract.gschema.xml:24
msgid "Maximum number of UTF-8 bytes to extract."
msgstr "ຈຳນວນສູງສຸດຂອງໄບຕ໌ UTF-8 ທີ່ຈະສະກັດ."

#: data/org.freedesktop.Tracker.Extract.gschema.xml:30
msgid "Text file allowlist"
msgstr "ລາຍການໄຟລ໌ຂໍ້ຄວາມທີ່ອະນຸຍາດ"

#: data/org.freedesktop.Tracker.Extract.gschema.xml:31
msgid "Filename patterns for plain text documents that should be indexed"
msgstr "ຮູບແບບຊື່ໄຟລ໌ສຳລັບເອກະສານຂໍ້ຄວາມທຳມະດາທີ່ຄວນຈະຖືກຈັດດັດຊະນີ"

#: data/org.freedesktop.Tracker.Extract.gschema.xml:37
msgid "Wait for FS miner to be done before extracting"
msgstr "ລໍຖ້າໃຫ້ FS miner ສຳເລັດກ່ອນທຳການສະກັດ"

#: data/org.freedesktop.Tracker.Extract.gschema.xml:38
msgid ""
"When true, tracker-extract will wait for tracker-miner-fs to be done "
"crawling before extracting meta-data. This option is useful on constrained "
"environment where it is important to list files as fast as possible and can "
"wait to get meta-data later."
msgstr "ເມື່ອເປັນຈິງ, tracker-extract ຈະລໍຖ້າໃຫ້ tracker-miner-fs ສຳເລັດການກວາດຂໍ້ມູນກ່ອນທີ່ຈະສະກັດຂໍ້ມູນເມຕາ. ຕົວເລືອກນີ້ມີປະໂຫຍດໃນສະພາບແວດລ້ອມທີ່ຈຳກັດ ເຊິ່ງເປັນສິ່ງສຳຄັນທີ່ຈະຕ້ອງສະແດງລາຍການໄຟລ໌ໃຫ້ໄວທີ່ສຸດ ແລະ ສາມາດລໍຖ້າຮັບຂໍ້ມູນເມຕາພາຍຫຼັງໄດ້."

#: data/org.freedesktop.Tracker.FTS.gschema.xml:24
msgid "Enable stemmer"
msgstr "ເປີດໃຊ້ໂຕຕັດຄຳ"

#: data/org.freedesktop.Tracker.FTS.gschema.xml:25
#: data/org.freedesktop.Tracker.FTS.gschema.xml:31
#: data/org.freedesktop.Tracker.FTS.gschema.xml:37
#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:24
#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:31
#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:38
#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:45
#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:52
#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:71
#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:77
#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:83
msgid "This setting is deprecated"
msgstr "ການຕັ້ງຄ່ານີ້ຖືກຍົກເລີກແລ້ວ"

#: data/org.freedesktop.Tracker.FTS.gschema.xml:30
msgid "Enable unaccent"
msgstr "ເປີດໃຊ້ການຕັດວັນນະຍຸດ"

#: data/org.freedesktop.Tracker.FTS.gschema.xml:36
msgid "Ignore numbers"
msgstr "ບໍ່ສົນໃຈຕົວເລກ"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:23
msgid "Initial sleep"
msgstr "ການຢຸດຊົ່ວຄາວເບື້ອງຕົ້ນ"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:30
msgid "Throttle"
msgstr "ການຄວບຄຸມຄວາມໄວ"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:37
msgid "Low disk space limit"
msgstr "ຂີດຈຳກັດພື້ນທີ່ດິສກ໌ຕ່ຳ"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:44
msgid "Crawling interval"
msgstr "ຊ່ວງເວລາການກວາດຂໍ້ມູນ"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:51
msgid "Removable devices’ data permanence threshold"
msgstr "ຂີດຈຳກັດຄວາມຄົງທີ່ຂອງຂໍ້ມູນອຸປະກອນທີ່ຖອດອອກໄດ້"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:58
msgid "Enable monitors"
msgstr "ເປີດໃຊ້ໂຕຕິດຕາມ"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:59
msgid "Set to false to completely disable any file monitoring"
msgstr "ຕັ້ງເປັນເທັດເພື່ອປິດການຕິດຕາມໄຟລ໌ທັງໝົດ"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:64
msgid "Index removable devices"
msgstr "ຈັດດັດຊະນີອຸປະກອນທີ່ຖອດອອກໄດ້"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:65
msgid ""
"Set to true to enable indexing mounted directories for removable devices."
msgstr "ຕັ້ງເປັນຈິງເພື່ອເປີດໃຊ້ການຈັດດັດຊະນີໄດເລກະທໍຣີທີ່ເຊື່ອມຕໍ່ສຳລັບອຸປະກອນທີ່ຖອດອອກໄດ້."

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:70
msgid "Index optical discs"
msgstr "ຈັດດັດຊະນີແຜ່ນດິສກ໌ອັອບຕິກ"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:76
msgid "Index when running on battery"
msgstr "ຈັດດັດຊະນີເມື່ອໃຊ້ງານດ້ວຍແບັດເຕີຣີ"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:82
msgid "Perform initial indexing when running on battery"
msgstr "ທຳການຈັດດັດຊະນີເບື້ອງຕົ້ນເມື່ອໃຊ້ງານດ້ວຍແບັດເຕີຣີ"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:88
msgid "Directories to index recursively"
msgstr "ໄດເລກະທໍຣີທີ່ຈະຈັດດັດຊະນີແບບຕໍ່ເນື່ອງ"

#. Translators: Do NOT translate the directories names in capital. Those
#. are keys used by Tracker.
#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:91
msgid ""
"List of directories to index recursively, Special values include: "
"‘&DESKTOP’, ‘&DOCUMENTS’, ‘&DOWNLOAD’, ‘&MUSIC’, ‘&PICTURES’, "
"‘&PUBLIC_SHARE’, ‘&TEMPLATES’, ‘&VIDEOS’. See /etc/xdg/user-dirs.defaults "
"and $HOME/.config/user-dirs.default"
msgstr "ລາຍການໄດເລກະທໍຣີທີ່ຈະຈັດດັດຊະນີແບບຕໍ່ເນື່ອງ, ຄ່າພິເສດປະກອບມີ: ‘&DESKTOP’, ‘&DOCUMENTS’, ‘&DOWNLOAD’, ‘&MUSIC’, ‘&PICTURES’, ‘&PUBLIC_SHARE’, ‘&TEMPLATES’, ‘&VIDEOS’. ເບິ່ງທີ່ /etc/xdg/user-dirs.defaults ແລະ $HOME/.config/user-dirs.default"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:102
msgid "Directories to index non-recursively"
msgstr "ໄດເລກະທໍຣີທີ່ຈະຈັດດັດຊະນີແບບບໍ່ຕໍ່ເນື່ອງ"

#. Translators: Do NOT translate the directories names in capital. Those
#. are keys used by Tracker.
#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:105
msgid ""
"List of directories to index without inspecting subfolders, Special values "
"include: ‘&DESKTOP’, ‘&DOCUMENTS’, ‘&DOWNLOAD’, ‘&MUSIC’, ‘&PICTURES’, "
"‘&PUBLIC_SHARE’, ‘&TEMPLATES’, ‘&VIDEOS’. See /etc/xdg/user-dirs.defaults "
"and $HOME/.config/user-dirs.default"
msgstr "ລາຍການໄດເລກະທໍຣີທີ່ຈະຈັດດັດຊະນີໂດຍບໍ່ກວດສອບໂຟລເດີຍ່ອຍ, ຄ່າພິເສດປະກອບມີ: ‘&DESKTOP’, ‘&DOCUMENTS’, ‘&DOWNLOAD’, ‘&MUSIC’, ‘&PICTURES’, ‘&PUBLIC_SHARE’, ‘&TEMPLATES’, ‘&VIDEOS’. ເບິ່ງທີ່ /etc/xdg/user-dirs.defaults ແລະ $HOME/.config/user-dirs.default"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:116
msgid "Ignored files"
msgstr "ໄຟລ໌ທີ່ບໍ່ສົນໃຈ"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:117
msgid "List of file patterns to avoid"
msgstr "ລາຍການຮູບແບບໄຟລ໌ທີ່ຄວນຫຼີກລ້ຽງ"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:122
msgid "Ignored directories"
msgstr "ໄດເລກະທໍຣີທີ່ບໍ່ສົນໃຈ"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:123
msgid "List of directories to avoid"
msgstr "ລາຍການໄດເລກະທໍຣີທີ່ຄວນຫຼີກລ້ຽງ"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:128
msgid "Ignored directories with content"
msgstr "ໄດເລກະທໍຣີທີ່ບໍ່ສົນໃຈພ້ອມເນື້ອຫາ"

#: data/org.freedesktop.Tracker.Miner.Files.gschema.xml:129
msgid "Avoid any directory containing a file blocklisted here"
msgstr "ຫຼີກລ້ຽງໄດເລກະທໍຣີໃດໆທີ່ມີໄຟລ໌ທີ່ຢູ່ໃນບັນຊີດຳນີ້"

#: src/cli/main.c:68
msgid "Show help on subcommands"
msgstr "ສະແດງການຊ່ວຍເຫຼືອສຳລັບຄຳສັ່ງຍ່ອຍ"

#: src/cli/main.c:69
msgid "Show metadata extractor output"
msgstr "ສະແດງຜົນການສະກັດຂໍ້ມູນເມຕາ"

#: src/cli/main.c:70 src/cli/tracker-index.c:374
