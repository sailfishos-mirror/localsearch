msgstr "ສະແດງສະຖານະ ແລະ ສະຖິຕິຂອງຂໍ້ມູນທີ່ຖືກຈັດດັດຊະນີ"

#: src/cli/main.c:76 src/cli/tracker-tag.c:414
msgid "Add, remove and list tags"
msgstr "ເພີ່ມ, ລົບ ແລະ ສະແດງລາຍການປ້າຍກຳກັບ"

#: src/cli/main.c:77
msgid "Sandbox for a testing environment"
msgstr "ສະພາບແວດລ້ອມທົດລອງສຳລັບການທົດສອບ"

#: src/cli/main.c:122
msgid "Available localsearch commands are:"
msgstr "ຄຳສັ່ງ localsearch ທີ່ມີໃຫ້ໃຊ້ແມ່ນ:"

#: src/cli/main.c:141
msgid "See “localsearch help <command>” to read about a specific subcommand."
msgstr "ເບິ່ງທີ່ “localsearch help <command>” ເພື່ອອ່ານກ່ຽວກັບຄຳສັ່ງຍ່ອຍສະເພາະ."

#: src/cli/main.c:184
#, c-format
msgid "“%s” is not a localsearch command. See “localsearch --help”"
msgstr "“%s” ບໍ່ແມ່ນຄຳສັ່ງ localsearch. ເບິ່ງທີ່ “localsearch --help”"

